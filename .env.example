# ──────────────────────────────────────────────────────────────────────────
# Modèle de variables d'environnement — Marketing Studio
#
# ⚠️ NE PAS mettre de vraies clés ici. Copie ce fichier en `.env.local`
#    (lu par Next.js ET drizzle) et renseigne les valeurs réelles dedans :
#       cp .env.example .env.local
#
# `.env.local` est gitignoré. N'utilise PAS un fichier `.env` séparé :
# Next.js donne la priorité à `.env.local`, une clé dans `.env` serait ignorée.
# ──────────────────────────────────────────────────────────────────────────

# ── IA : clé unique AIML (10 modèles max activés sur la clé) ────────────────
# C'est ICI que va ta clé API AIML.
AIMLAPI_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────
# Exposées au client (préfixe NEXT_PUBLIC_) — non secrètes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service-role — SECRÈTE, serveur uniquement, ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Base de données (drizzle) ──────────────────────────────────────────────
# Utilise le pooler Supabase en prod (le host direct est IPv6-only).
DATABASE_URL=

# ── Clonage vocal ElevenLabs (optionnel — Campagne Spéciale) ───────────────
# Appelé en direct (hors quota AIML). Laisser vide tant que non utilisé.
ELEVENLABS_API_KEY=
# Active le clonage vocal gated. Mettre "true" pour l'activer.
ELEVENLABS_CLONE_ENABLED=
